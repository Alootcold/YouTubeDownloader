<Page x:Class="YouTubeDownloader.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:YouTubeDownloader.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="YouTube视频下载" FontSize="28" FontWeight="Bold" Margin="0,8,0,24"/>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="UrlTextBox"
                     PlaceholderText="请输入YouTube视频链接..."
                     Text="{Binding VideoUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="16"
                     Height="48"
                     VerticalAlignment="Center"
                     Padding="12,12,12,0"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                <Button Content="解析"
                        Command="{Binding ParseCommand}"
                        Width="100"
                        Height="48"
                        IsEnabled="{Binding CanParse}"/>
                <Button Content="清空"
                        Command="{Binding ClearCommand}"
                        Width="80"
                        Height="48"
                        Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>

        <ProgressBar Grid.Row="2"
                     IsIndeterminate="{Binding IsLoading}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                     Height="4"
                     Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="3"
                      Visibility="{Binding HasVideoInfo, Converter={StaticResource BoolToVisibilityConverter}}"
                      Margin="0,0,0,12">
            <StackPanel>
                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0"
                               Source="{Binding VideoInfo.ThumbnailUrl}"
                               Width="200"
                               Height="112"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Left"/>

                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding VideoInfo.Title}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       MaxHeight="50"/>
                            <TextBlock Margin="0,8,0,0">
                                <Run Text="时长: "/>
                                <Run Text="{Binding VideoInfo.Duration}"/>
                                <Run Text="  |  上传者: "/>
                                <Run Text="{Binding VideoInfo.Uploader}"/>
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0">
                                <Run Text="观看: "/>
                                <Run Text="{Binding VideoInfo.ViewCount}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                    <TextBlock Text="选择画质:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox ItemsSource="{Binding AvailableQualities}"
                              SelectedItem="{Binding SelectedQuality, Mode=TwoWay}"
                              Width="120"
                              Height="32"
                              VerticalAlignment="Center"/>
                    <Button Content="开始下载"
                            Command="{Binding DownloadCommand}"
                            Margin="24,0,0,0"
                            Width="120"
                            Height="32"
                            VerticalAlignment="Center"/>
                    <Button Content="取消"
                            Command="{Binding CancelCommand}"
                            Margin="8,0,0,0"
                            Width="80"
                            Height="32"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Margin="0,16,0,0">
            <Grid Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ProgressBar Grid.Column="0"
                                 Value="{Binding DownloadProgress}"
                                 Maximum="100"
                                 Height="24"/>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="14"
                               Text="{Binding DownloadProgressText}"/>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="{Binding DownloadStatus}" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text=" | " Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="{Binding DownloadSpeed}" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="4"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,24,0,0"
                Visibility="{Binding HasVideoInfo, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="💡 温馨提示" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="使用方法：" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Text="1. 在上方输入框粘贴 YouTube 视频链接（支持 youtube.com 和 youtu.be 格式）" FontSize="13" Margin="8,0,0,2"/>
                <TextBlock Text="2. 点击&quot;解析&quot;按钮获取视频信息" FontSize="13" Margin="8,0,0,2"/>
                <TextBlock Text="3. 选择想要的画质（best=最佳画质）" FontSize="13" Margin="8,0,0,2"/>
                <TextBlock Text="4. 点击&quot;开始下载&quot;按钮下载视频" FontSize="13" Margin="8,0,0,8"/>

                <TextBlock Text="注意事项：" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Text="• 首次使用时，需进入设置点击&quot;更新全部引擎&quot;按钮以下载引擎；后续如需更新，同样在设置中点击该按钮即可" FontSize="13" Margin="8,0,0,2"/>
                <TextBlock Text="• 首次使用需要下载引擎，请保持网络连接" FontSize="13" Margin="8,0,0,2"/>
                <TextBlock Text="• 下载的视频保存在&quot;视频\YouTubeDownloader&quot;文件夹中" FontSize="13" Margin="8,0,0,2"/>
                <TextBlock Text="• 可在&quot;设置&quot;页面修改默认下载路径" FontSize="13" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>